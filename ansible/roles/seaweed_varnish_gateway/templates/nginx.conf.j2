server {
    listen {{ gateway_https_port }} ssl;
    server_name {{ gateway_public_hostname }};

    ssl_certificate {{ gateway_tls_certificate_path }};
    ssl_certificate_key {{ gateway_tls_private_key_path }};
    ssl_protocols TLSv1.2 TLSv1.3;

    location = /healthz {
        access_log off;
        add_header Cache-Control "no-store" always;
        default_type text/plain;
        return 200 "ok\n";
    }

    location / {
        if ($request_method !~ ^(GET|HEAD)$) {
            return 405;
        }
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_pass http://127.0.0.1:{{ gateway_varnish_port }};
    }
}
