# Explicit image tags make this local demo reproducible.
SEAWEEDFS_IMAGE=chrislusf/seaweedfs:4.39
VARNISH_IMAGE=varnish:9.0.3-1
NGINX_IMAGE=nginx:1.30.3-alpine
PYTHON_IMAGE=python:3.13.7-alpine
VARNISH_INIT_IMAGE=busybox:1.37.0

# Only Nginx is publicly published. Varnish is bound to 127.0.0.1 for PURGE.
S3_HTTPS_PORT=8443
VARNISH_PURGE_PORT=6081

S3_BUCKET=cache-demo
SEED_OBJECT_COUNT=64

# A fixed-size Varnish file storage backend. It is not a SeaweedFS quota.
VARNISH_DISK_SIZE=32M
